# ────────────────────────────────────────────────────────────────────────────────
# .env.e2e.example — Variáveis de ambiente para os testes E2E com Playwright
# Copie este arquivo para .env.e2e e preencha com as credenciais reais.
# O .env.e2e está no .gitignore e nunca deve ser commitado.
# ────────────────────────────────────────────────────────────────────────────────

# Conta de teste no Supabase Cloud (conta real, NÃO de produção do Fábio)
# Pré-condições necessárias na conta de teste:
#   - Ao menos 1 familiar cadastrado
#   - Ao menos 1 medicamento ativo (para o teste de marcação de dose)
TEST_USER_EMAIL=teste@exemplo.com
TEST_USER_PASSWORD=senha-da-conta-de-teste

# URL base do frontend rodando localmente (bun run dev)
# Padrão: http://localhost:8080 — altere se a porta for diferente
E2E_BASE_URL=http://localhost:8080
